# ─────────────────────────────────────────────────────────────────────────────
# my-champions environment template
# Copy this file to .env and fill in all values.
# .env is gitignored and must never be committed.
#
# For CI: populate the ENV_FILE GitHub secret with all variables below.
# ─────────────────────────────────────────────────────────────────────────────

# Build variant — set to 'prod' for production builds; omit or set to 'dev' otherwise.
APP_VARIANT=dev

# ── Firebase Dev Configuration (APP_VARIANT=dev) ─────────────────────────────
FIREBASE_DEV_API_KEY=
FIREBASE_DEV_AUTH_DOMAIN=
FIREBASE_DEV_PROJECT_ID=
FIREBASE_DEV_STORAGE_BUCKET=
FIREBASE_DEV_MESSAGING_SENDER_ID=
FIREBASE_DEV_APP_ID=
FIREBASE_DEV_IOS_CLIENT_ID=
FIREBASE_DEV_ANDROID_CLIENT_ID=
FIREBASE_DEV_WEB_CLIENT_ID=
FIREBASE_DEV_IOS_APP_ID=
FIREBASE_DEV_ANDROID_APP_ID=

# ── Firebase Prod Configuration (APP_VARIANT=prod) ───────────────────────────
FIREBASE_PROD_API_KEY=
FIREBASE_PROD_AUTH_DOMAIN=
FIREBASE_PROD_PROJECT_ID=
FIREBASE_PROD_STORAGE_BUCKET=
FIREBASE_PROD_MESSAGING_SENDER_ID=
FIREBASE_PROD_APP_ID=
FIREBASE_PROD_IOS_CLIENT_ID=
FIREBASE_PROD_ANDROID_CLIENT_ID=
FIREBASE_PROD_WEB_CLIENT_ID=
FIREBASE_PROD_IOS_APP_ID=
FIREBASE_PROD_ANDROID_APP_ID=

# ── Firebase Data Connect (optional) ─────────────────────────────────────────
# Required only when running npm run validate:data-connect:profile or
# using Data Connect from the app. Leave blank to disable.
EXPO_PUBLIC_DATA_CONNECT_GRAPHQL_ENDPOINT=
EXPO_PUBLIC_DATA_CONNECT_API_KEY=
