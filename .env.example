# ─────────────────────────────────────────────────────────────────────────────
# my-champions environment template
# Copy this file to .env and fill in all values.
# .env is gitignored and must never be committed.
#
# For CI: populate the ENV_FILE GitHub secret with all variables below.
# ─────────────────────────────────────────────────────────────────────────────

# Build variant — set to 'prod' for production builds; omit or set to 'dev' otherwise.
APP_VARIANT=dev

# ── Firebase Dev Configuration (APP_VARIANT=dev) ─────────────────────────────
FIREBASE_DEV_API_KEY=
FIREBASE_DEV_AUTH_DOMAIN=
FIREBASE_DEV_PROJECT_ID=
FIREBASE_DEV_STORAGE_BUCKET=
FIREBASE_DEV_MESSAGING_SENDER_ID=
FIREBASE_DEV_APP_ID=
FIREBASE_DEV_IOS_CLIENT_ID=
FIREBASE_DEV_ANDROID_CLIENT_ID=
FIREBASE_DEV_WEB_CLIENT_ID=
FIREBASE_DEV_IOS_APP_ID=
FIREBASE_DEV_ANDROID_APP_ID=

# ── Firebase Prod Configuration (APP_VARIANT=prod) ───────────────────────────
FIREBASE_PROD_API_KEY=
FIREBASE_PROD_AUTH_DOMAIN=
FIREBASE_PROD_PROJECT_ID=
FIREBASE_PROD_STORAGE_BUCKET=
FIREBASE_PROD_MESSAGING_SENDER_ID=
FIREBASE_PROD_APP_ID=
FIREBASE_PROD_IOS_CLIENT_ID=
FIREBASE_PROD_ANDROID_CLIENT_ID=
FIREBASE_PROD_WEB_CLIENT_ID=
FIREBASE_PROD_IOS_APP_ID=
FIREBASE_PROD_ANDROID_APP_ID=

# ── Firebase Data Connect Runtime Selection ──────────────────────────────────
# One Firebase project can host multiple Data Connect services.
# The app picks DEV/PROD service IDs by APP_VARIANT.
EXPO_PUBLIC_DATA_CONNECT_CONNECTOR_ID=mychampions
EXPO_PUBLIC_DATA_CONNECT_SERVICE_ID_DEV=
EXPO_PUBLIC_DATA_CONNECT_LOCATION_DEV=us-east4
EXPO_PUBLIC_DATA_CONNECT_SERVICE_ID_PROD=
EXPO_PUBLIC_DATA_CONNECT_LOCATION_PROD=us-east4

# ── Firebase Data Connect Endpoint Validation (script-only) ──────────────────
# Used by npm run validate:data-connect:profile (HTTP-over-GraphQL contract check).
# Runtime app access uses generated SDK + connector/service/location above.
EXPO_PUBLIC_DATA_CONNECT_GRAPHQL_ENDPOINT=
EXPO_PUBLIC_DATA_CONNECT_API_KEY=

# ── Terms Acceptance Gate ────────────────────────────────────────────────────
# Required terms version and URL displayed in /auth/accept-terms.
# This is a client-side config fallback while Data Connect profile terms fields
# are pending wiring.
EXPO_PUBLIC_TERMS_REQUIRED_VERSION=v1
EXPO_PUBLIC_TERMS_URL=https://google.com

# ── fatsecret Food Search (Cloud Function proxy) ──────────────────────────────
# URL of the deployed Firebase Cloud Function that proxies fatsecret food search.
# The Cloud Function holds fatsecret Client ID and Secret server-side (never in binary).
# Leave blank until the Cloud Function is deployed.
# Refs: D-113, D-127, BL-106, FR-243
EXPO_PUBLIC_FOOD_SEARCH_FUNCTION_URL=

# ── AI Meal Photo Analysis (Cloud Function proxy) ─────────────────────────────
# URL of the deployed Firebase Cloud Function that proxies OpenAI GPT-4o Vision.
# The Cloud Function holds the OpenAI API key server-side (never in binary).
# Leave blank until the Cloud Function is deployed.
# Refs: D-106–D-110, BL-108, FR-229–FR-239
EXPO_PUBLIC_MEAL_ANALYSIS_FUNCTION_URL=

# ── RevenueCat ────────────────────────────────────────────────────────────────
# Public SDK key for the RevenueCat project (safe to ship in binary — not a secret).
# Use the Apple/Google store key for production; test/sandbox key for dev builds.
# Refs: D-130, BL-107, FR-126–129, BR-218–221, SC-204, SC-206, SC-212
EXPO_PUBLIC_REVENUECAT_API_KEY=
