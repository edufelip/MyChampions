# ─────────────────────────────────────────────────────────────────────────────
# my-champions environment template
# Copy this file to .env and fill in all values.
# .env is gitignored and must never be committed.
#
# For CI: populate the ENV_FILE GitHub secret with all variables below.
# ─────────────────────────────────────────────────────────────────────────────

# Build variant — set to 'prod' for production builds; omit or set to 'dev' otherwise.
APP_VARIANT=dev

# ── Firebase Dev Configuration (APP_VARIANT=dev) ─────────────────────────────
FIREBASE_DEV_API_KEY=
FIREBASE_DEV_AUTH_DOMAIN=
FIREBASE_DEV_PROJECT_ID=mychampions-fb928
FIREBASE_DEV_STORAGE_BUCKET=
FIREBASE_DEV_MESSAGING_SENDER_ID=
FIREBASE_DEV_APP_ID=
FIREBASE_DEV_IOS_CLIENT_ID=
FIREBASE_DEV_ANDROID_CLIENT_ID=
FIREBASE_DEV_WEB_CLIENT_ID=
FIREBASE_DEV_IOS_APP_ID=
FIREBASE_DEV_ANDROID_APP_ID=

# ── Firebase Prod Configuration (APP_VARIANT=prod) ───────────────────────────
FIREBASE_PROD_API_KEY=
FIREBASE_PROD_AUTH_DOMAIN=
FIREBASE_PROD_PROJECT_ID=mychampions-fb928
FIREBASE_PROD_STORAGE_BUCKET=
FIREBASE_PROD_MESSAGING_SENDER_ID=
FIREBASE_PROD_APP_ID=
FIREBASE_PROD_IOS_CLIENT_ID=
FIREBASE_PROD_ANDROID_CLIENT_ID=
FIREBASE_PROD_WEB_CLIENT_ID=
FIREBASE_PROD_IOS_APP_ID=
FIREBASE_PROD_ANDROID_APP_ID=

# ── Firestore Validation (script-only) ───────────────────────────────────────
# Used by npm run validate:firestore:smoke.
# FIRESTORE_ID_TOKEN must be a Firebase Auth ID token for the selected project.
FIRESTORE_ID_TOKEN=

# ── Terms Acceptance Gate ────────────────────────────────────────────────────
# Required terms version and URL displayed in /auth/accept-terms.
# This is a client-side config fallback while Firestore profile terms fields
# are pending wiring.
EXPO_PUBLIC_TERMS_REQUIRED_VERSION=v1
EXPO_PUBLIC_TERMS_URL=https://portfolio.eduwaldo.com/projects/my-champions/terms_of_use
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://portfolio.eduwaldo.com/projects/my-champions/privacy_policy

# ── Debug Logging ──────────────────────────────────────────────────────────────
# Global debug switch for source/network logs used by microservices and Firebase
# source modules.
# - true  => force enable debug logs
# - false => force disable debug logs
# - unset => auto-enable in __DEV or APP_VARIANT=dev
EXPO_PUBLIC_DEBUG_LOGS=

# ── Food Search Microservice ───────────────────────────────────────────────────
# URL of the VPS food-search endpoint.
# This endpoint expects Firebase ID token authentication.
# Refs: BL-106, FR-243
EXPO_PUBLIC_FOOD_SEARCH_SERVICE_URL=https://foodservice.eduwaldo.com/searchFoods

# ── AI Meal Photo Analysis (Cloud Function proxy) ─────────────────────────────
# URL of the deployed Firebase Cloud Function that proxies OpenAI GPT-4o Vision.
# The Cloud Function holds the OpenAI API key server-side (never in binary).
# Leave blank until the Cloud Function is deployed.
# Refs: D-106–D-110, BL-108, FR-229–FR-239
EXPO_PUBLIC_MEAL_ANALYSIS_FUNCTION_URL=

# ── RevenueCat ────────────────────────────────────────────────────────────────
# Public SDK keys for the RevenueCat project (safe to ship in binary — not secret).
# iOS must use appl_* and Android must use goog_*.
# Variant-specific keys are preferred:
# - APP_VARIANT=dev  -> *_DEV keys (bundle/package .dev)
# - APP_VARIANT=prod -> *_PROD keys (production bundle/package)
# Refs: D-130, BL-107, FR-126–129, BR-218–221, SC-204, SC-206, SC-212
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS_DEV=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID_DEV=
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS_PROD=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID_PROD=

# ── Exercise Service Microservice (proxy) ─────────────────────────────────────
# Base URL for the exercise proxy service used by SC-208 exercise search.
# Mobile must never send upstream YMove API keys; service injects them server-side.
EXPO_PUBLIC_EXERCISE_SERVICE_URL=https://exerciseservice.eduwaldo.com
