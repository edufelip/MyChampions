# Firebase Data Connect — generated SDK (rebuilt via `firebase dataconnect:sdk:generate`)
features/dataconnect-generated/

# macOS
.DS_Store
*.pem

# local env files — never commit real values; use .env.example as template
.env
.env.local
.env.dev
.env.prod
.env*.local

# scratch / debug scripts
test-dc*.ts
test-dc*.js

# iOS/Android Firebase configs
GoogleService-Info.plist
GoogleService-Info-Dev.plist
GoogleService-Info-Prod.plist
ios/GoogleService-Info.plist
ios/GoogleService-Info-Dev.plist
ios/GoogleService-Info-Prod.plist
**/google-services.json
google-services-dev.json

# typescript
*.tsbuildinfo

app-example
