{
  "name": "my-champions",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "icons": "node scripts/generate-icons.mjs",
    "android": "expo run:android",
    "android:dev": "EXPO_PUBLIC_ENV=dev APP_VARIANT=dev expo run:android --variant devDebug --app-id com.edufelip.mychampions.dev",
    "android:prod": "EXPO_PUBLIC_ENV=dev APP_VARIANT=prod expo run:android --variant productionDebug",
    "android:release": "EXPO_PUBLIC_ENV=prod APP_VARIANT=prod EXPO_NO_DEV_CLIENT=1 ./android/gradlew -p android app:assembleProductionRelease -x lint -x test --configure-on-demand --build-cache",
    "android:release:device": "EXPO_PUBLIC_ENV=prod APP_VARIANT=prod EXPO_NO_DEV_CLIENT=1 ./android/gradlew -p android app:assembleProductionRelease -PlocalReleaseInstall=true -x lint -x test --configure-on-demand --build-cache && adb install -r android/app/build/outputs/apk/production/release/app-production-release.apk",
    "check:ios-firebase": "node scripts/check-ios-firebase-config.mjs",
    "ios": "npm run check:ios-firebase && expo run:ios",
    "ios:dev": "EXPO_PUBLIC_ENV=dev APP_VARIANT=dev npm run check:ios-firebase && EXPO_PUBLIC_ENV=dev APP_VARIANT=dev expo run:ios --scheme mychampions",
    "ios:prod": "EXPO_PUBLIC_ENV=prod APP_VARIANT=prod npm run check:ios-firebase && EXPO_PUBLIC_ENV=prod APP_VARIANT=prod expo run:ios --scheme mychampions",
    "ios:release": "EXPO_PUBLIC_ENV=prod APP_VARIANT=prod EXPO_NO_DEV_CLIENT=1 npm run check:ios-firebase && EXPO_PUBLIC_ENV=prod APP_VARIANT=prod EXPO_NO_DEV_CLIENT=1 expo run:ios --scheme mychampions --configuration Release",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "npm run test:unit",
    "test:unit": "tsx --test features/**/*.test.ts localization/**/*.test.ts",
    "test:e2e:build:ios": "detox build -c ios.sim.release",
    "test:e2e:ios": "detox test -c ios.sim.release",
    "test:e2e:build:ios:debug": "detox build -c ios.sim.debug",
    "test:e2e:ios:debug": "detox test -c ios.sim.debug",
    "test:e2e:build:android": "detox build -c android.emu.release",
    "test:e2e:android": "detox test -c android.emu.release",
    "test:e2e:build:android:debug": "detox build -c android.emu.debug",
    "test:e2e:android:debug": "detox test -c android.emu.debug",
    "test:e2e": "npm run test:e2e:ios",
    "validate:firestore:smoke": "node scripts/validate-firestore-smoke.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.10.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-purchases": "^9.10.5",
    "react-native-purchases-ui": "^9.10.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "detox": "^20.47.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
